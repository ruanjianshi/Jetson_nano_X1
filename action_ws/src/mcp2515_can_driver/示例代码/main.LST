  37          /************************************************************************
  38          *函数原型: void init_serialcomm(void)            *
  39          *参数说明: 串口初始化                            *
  40          *说明: 设值单片机的定时器1的方式选择波特率 。该子程序只能用于复位模式
  41          ************************************************************************/
  42          void init_serialcomm(void)
  43          {
  44   1        SCON  = 0x50;       //SCON: serail mode 1, 8-bit UART, enable ucvr 
  45   1        TMOD |= 0x20;       //TMOD: timer 1, mode 2, 8-bit reload 
  46   1        PCON |= 0x80;       //SMOD=1; 
  47   1        TH1   = 0xF4;       //Baud:4800  fosc=11.0592MHz  
  48   1        TL1   = 0xF4;       //
  49   1        IE   |= 0x90;       //Enable Serial Interrupt 
  50   1        TR1   = 1;          // timer 1 run
  51   1      }
  52          
  53          //定时器0初始化
  54          void timer0initial()
  55          {
C51 COMPILER V9.00   MAIN                                                                  05/18/2016 11:05:12 PAGE 2   

  56   1        TMOD|=0x1;        //工作方式16位定时计数器
  57   1        TH0=0xb8;TL0=0x00;  //50MS定时初值（T0计时用）
  58   1        IE|=0x90;       //Enable Serial Interrupt 
  59   1        ET0=0;
  60   1        TR0=0;
  61   1      }
  62          
  63          //向串口发送一个字符
  64          void send_char_com(unsigned char ch)
  65          {
  66   1        SBUF=ch;
  67   1        while(!TI);
  68   1        TI=0;
  69   1      }
  70          
  71          //向串口发送一个字符串,strlen为该字符串长度
  72          void send_string_com(unsigned char *str,unsigned int strlen)
  73          {
  74   1        unsigned int k=0;
  75   1        do
  76   1        {
  77   2          send_char_com(*(str+k));
  78   2          k++;
  79   2        }while(k<strlen);
  80   1      }
