  91          
  92          //串口接收中断函数
  93          void serial() interrupt 4 using 1
  94          {
  95   1        unsigned char ch;
  96   1      
  97   1        if(RI)
  98   1        {
  99   2          RI=0;
 100   2          ET0=1;TR0=1;
 101   2          ch=SBUF;
 102   2      
 103   2          inbuf1[count3]=ch;
 104   2          count3=count3+1;
 105   2          if(count3==INBUF_LEN)
 106   2          {
 107   3            ET0=0;
 108   3            TR0=0;
 109   3            TH0=0xb8;
 110   3            TL0=0x00;  //关闭定时中断，停止定时中断
 111   3            sRXFlag=1;
 112   3          }
 113   2        }
 114   1      }
