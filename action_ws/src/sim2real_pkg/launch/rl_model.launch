<launch>
  <arg name="model_path" default="$(find sim2real_pkg)/models/jump_model.onnx" />
  <arg name="inference_rate" default="50.0" />

  <node name="jump_model_inference" pkg="sim2real_pkg" type="rl_inference/rl_onnx_inference.py" output="screen">
    <param name="model_path" value="$(arg model_path)" />
    <param name="inference_rate" value="$(arg inference_rate)" />
  </node>
</launch>
